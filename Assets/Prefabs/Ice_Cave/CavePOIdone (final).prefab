  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\n\n\n\nDay 9 \u2013 Field Log\nWe have the data. Whatever is in this
    cave\u2026 it\u2019s not just geological. The team is gone. Something followed
    us in the dark.\L\nWe\u2019re heading back to the cruiser with the drives. That\u2019s
    all that matters now.\L\nIf anyone finds this \u2013"
  m_isRightToLeft: 0
