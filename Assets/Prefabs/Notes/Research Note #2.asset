  m_Script: {fileID: 11500000, guid: 7d349c6d2656e0146a55cb2c339a120c, type: 3}
  m_Name: Research Note #2
  m_EditorClassIdentifier: Assembly-CSharp::NoteData
  noteTitle: 
  noteText: "Arrived at the research station this morning.  \nVisibility in the vehicle
    is terrible, the storm hasn't let up for hours, but the navigation system works
    exactly as described. \nFollowing the peculier radio frequencies guide the route
    surprisingly well once you tune the radio right. \nIt would seem that each base
    has their own specific signal."
