  m_Script: {fileID: 11500000, guid: 7d349c6d2656e0146a55cb2c339a120c, type: 3}
  m_Name: CrashedCruiser#1
  m_EditorClassIdentifier: Assembly-CSharp::NoteData
  noteTitle: 
  noteText: "The storm isn\u2019t empty.\nSomething is in it.\nAnd every time you
    try to analyze the data, every time you push a little further\nyou\u2019re just
    calling it.\nI thought I was discovering something.\nI was just telling it where
    I was.\nIt doesn\u2019t need to see you.\nIt just needs you to listen."
  journalEntry: {fileID: 0}
