  m_Script: {fileID: 11500000, guid: 7d349c6d2656e0146a55cb2c339a120c, type: 3}
  m_Name: IntroNote
  m_EditorClassIdentifier: Assembly-CSharp::NoteData
  noteTitle: 
  noteText: "If you're reading this, the storm didn\u2019t take you.\nGood. \nOur
    bases in the area have gone dark.\nYou will continue their work.\nUse the radio
    in your vehicle. Tune the frequencies carefully. They\u2019ll guide you to each
    location.\nCollect whatever data you can, analyze it and move on.\nAnd listen,
    we don't know what's out there so don\u2019t go wandering out into the storm."
  journalEntry: {fileID: 0}
