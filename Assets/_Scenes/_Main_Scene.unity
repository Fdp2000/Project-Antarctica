    - target: {fileID: 5596622687143516412, guid: e5b3fe4d53d02be4e8bb8a09f2825dca, type: 3}
      propertyPath: m_text
      value: "The storm isn\u2019t empty.\nSomething is in it.\nAnd every time you
        try to analyze the data, every time you push a little further\nyou\u2019re
        just calling it.\nI thought I was discovering something.\nI was just telling
        it where I was.\nIt doesn\u2019t need to see you.\nIt just needs you to listen."
      objectReference: {fileID: 0}
