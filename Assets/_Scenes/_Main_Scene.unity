    - target: {fileID: 5596622687143516412, guid: e5b3fe4d53d02be4e8bb8a09f2825dca, type: 3}
      propertyPath: m_text
      value: "\n\n\nWelcome to Antarctica!\nOur bases in the area have gone dark.\nYou
        will continue their work.\nUse the radio in your vehicle. Tune the frequencies
        carefully. They\u2019ll guide you to each location.\nWhen you get there,
        collect whatever data you can, analyze it and move on.\nAnd listen, we don't
        know what's out there so don\u2019t go wandering out into the storm."
      objectReference: {fileID: 0}
